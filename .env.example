APP_NAME=KunnoTechTest
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Opcion A: SQLite (mas sencillo, no requiere instalar MySQL)
DB_CONNECTION=sqlite
# DB_DATABASE=database/kunno_test.sqlite

# Opcion B: MySQL (si tienes MySQL instalado)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=kunno_tech_test
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
